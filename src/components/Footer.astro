---
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-top">
      <div class="footer-col brand-col">
        <div class="brand-header">
          <img src={import.meta.env.BASE_URL + 'favicon.svg'} alt="Zorzal RF Logo" class="footer-logo" />
          <span class="brand-name">Zorzal RF</span>
        </div>
        <p class="brand-description">
          Especialistas en Radio Definida por Software (SDR) y sistemas de RF de alta performance.<br>
        </p>
      </div>
      
      <div class="footer-col">
        <h4 class="col-title">NAVEGACIÓN</h4>
        <ul class="col-links">
          <li><a href={import.meta.env.BASE_URL}>Inicio</a></li>
          <li><a href={import.meta.env.BASE_URL + 'catalog/'}>Catálogo</a></li>
          <li><a href="#" class="open-contact-dialog">Contacto</a></li>
        </ul>
      </div>
      
      <div class="footer-col">
        <h4 class="col-title">CATÁLOGO</h4>
        <ul class="col-links">
          <li><a href={import.meta.env.BASE_URL + 'catalog/?type=SDR'}>Receptores SDR</a></li>
          <li><a href={import.meta.env.BASE_URL + 'catalog/?type=Antena'}>Antenas</a></li>
          <li><a href={import.meta.env.BASE_URL + 'catalog/?type=Filtros'}>Filtros RF</a></li>
          <li><a href={import.meta.env.BASE_URL + 'catalog/?type=Accesorios'}>Accesorios</a></li>
        </ul>
      </div>
      
      <div class="footer-col">
        <h4 class="col-title">CONTACTO</h4>
        <ul class="col-links contact-info">
          <li><a href="#" class="protected-email" data-contact="hola" data-domain="zorzalrf.com">Cargando email...</a></li>
          <li class="address">Buenos Aires, Argentina</li>
        </ul>
      </div>
    </div>
    
    <div class="footer-bottom">
      <div class="copyright">
        &copy; {currentYear} Zorzal RF. Todos los derechos reservados.
      </div>
      <div class="disclaimer">
        Los equipos comercializados corresponden a hardware original, seleccionado y testeado.
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--color-card-bg);
    border-top: 1px solid var(--color-border);
    padding: 4rem 0 2rem;
    margin-top: 4rem;
  }
  
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  
  .footer-top {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 2rem;
    margin-bottom: 3rem;
  }
  
  .footer-col {
    display: flex;
    flex-direction: column;
  }
  
  .brand-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }
  
  .footer-logo {
    height: 40px;
    width: auto;
  }
  
  .brand-name {
    color: var(--color-orange);
    font-size: 1.5rem;
    font-weight: 700;
  }
  
  .brand-description {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    line-height: 1.6;
    margin: 0 0 1.5rem 0;
    max-width: 90%;
  }
  
  .social-links {
    display: flex;
    gap: 1rem;
  }
  
  .social-links a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background-color: var(--color-hover-bg);
    color: var(--color-text);
    font-size: 0.8rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s;
    border: 1px solid var(--color-border);
  }
  
  .social-links a:hover {
    background-color: var(--color-orange);
    color: var(--color-dark-gray);
    border-color: var(--color-orange);
  }
  
  .col-title {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-heading);
    margin: 0 0 1.5rem 0;
    letter-spacing: 1px;
    text-transform: uppercase;
  }
  
  .col-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  
  .col-links a, .contact-info li {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    transition: color 0.2s;
  }
  
  .col-links a:hover {
    color: var(--color-orange);
  }
  
  .contact-info .address {
    margin-top: 1rem;
  }
  
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
    gap: 2rem;
  }
  
  .copyright {
    color: var(--color-text);
    opacity: 0.85;
    font-size: 0.85rem;
  }
  
  .disclaimer {
    color: var(--color-text-muted);
    font-size: 0.85rem;
    max-width: 600px;
    text-align: right;
    line-height: 1.5;
  }
  
  @media (max-width: 900px) {
    .footer-top {
      grid-template-columns: 1fr 1fr;
    }
    .footer-bottom {
      flex-direction: column;
      text-align: center;
      align-items: center;
    }
    .disclaimer {
      text-align: center;
    }
  }
  
  @media (max-width: 600px) {
    .footer-top {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .brand-header {
      justify-content: center;
    }
    .social-links {
      justify-content: center;
    }
    .brand-description {
      margin: 0 auto 1.5rem auto;
    }
  }
</style>

<script>
  // Ofuscar el email para evitar spam bots
  document.querySelectorAll('.protected-email').forEach(link => {
    const contact = link.getAttribute('data-contact');
    const domain = link.getAttribute('data-domain');
    if (contact && domain) {
      const email = `${contact}@${domain}`;
      link.href = `mailto:${email}`;
      link.textContent = email;
    }
  });
</script>
