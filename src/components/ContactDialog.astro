---
import { catalogItems } from '../data/catalog';

// Get unique product titles and sort alphabetically
const productOptions = Array.from(new Set(catalogItems.map(item => item.title))).sort();
---
<dialog id="contact-dialog" class="contact-dialog">
  <div class="dialog-content">
    <div class="dialog-header">
      <h2>Contactar a Zorzal RF</h2>
      <button class="close-dialog" aria-label="Cerrar">&times;</button>
    </div>
    
    <form id="contact-form">
      <div class="form-group">
        <label for="motivo">Motivo de Consulta</label>
        <select id="motivo" name="motivo" required>
          <option value="" disabled selected>Seleccioná un motivo...</option>
          <option value="Soporte Técnico">Soporte Técnico</option>
          <option value="Ventas">Ventas</option>
          <option value="Otro">Otro</option>
        </select>
      </div>

      <div class="form-group">
        <label for="modelo">Modelo de Equipo / Proyecto</label>
        <select id="modelo" name="modelo" required>
          <option value="" disabled selected>Seleccioná el modelo o proyecto...</option>
          {productOptions.map(product => (
            <option value={product}>{product}</option>
          ))}
          <option value="Consulta General / Otro Proyecto">Consulta General / Otro Proyecto</option>
        </select>
      </div>

      <div class="form-group">
        <label for="descripcion">Descripción</label>
        <textarea id="descripcion" name="descripcion" rows="4" placeholder="Escribí los detalles de tu consulta acá..." required></textarea>
      </div>

      <div class="dialog-footer">
        <button type="button" class="btn-secondary close-dialog">Cancelar</button>
        <button type="submit" class="btn-primary">Enviar Consulta</button>
      </div>
    </form>
  </div>
</dialog>

<style>
  .contact-dialog {
    border: none;
    border-radius: 8px;
    background-color: var(--color-card-bg);
    color: var(--color-text);
    padding: 0;
    width: 90%;
    max-width: 500px;
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.5), 0 10px 10px -5px rgba(0, 0, 0, 0.3);
    outline: 1px solid var(--color-border);
  }
  
  .contact-dialog::backdrop {
    background-color: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
  }

  .dialog-content {
    padding: 1.5rem;
  }

  .dialog-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 1rem;
  }

  .dialog-header h2 {
    margin: 0;
    font-size: 1.25rem;
    color: var(--color-orange);
  }

  .close-dialog {
    background: none;
    border: none;
    font-size: 1.5rem;
    color: var(--color-text-muted);
    cursor: pointer;
    line-height: 1;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    transition: background-color 0.2s, color 0.2s;
  }

  .close-dialog:hover {
    color: var(--color-text);
    background: var(--color-hover-bg);
  }

  .form-group {
    margin-bottom: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .form-group label {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-heading);
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    background-color: var(--color-bg);
    color: var(--color-text);
    font-family: inherit;
    font-size: 0.95rem;
    transition: border-color 0.2s;
    box-sizing: border-box;
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-orange);
  }

  .dialog-footer {
    display: flex;
    justify-content: flex-end;
    gap: 1rem;
    margin-top: 2rem;
  }

  .btn-primary, .btn-secondary {
    padding: 0.6rem 1.2rem;
    border-radius: 4px;
    font-weight: bold;
    cursor: pointer;
    font-size: 0.95rem;
    border: none;
    transition: background-color 0.2s, color 0.2s;
  }

  .btn-primary {
    background-color: var(--color-orange);
    color: #333333;
  }

  .btn-primary:hover {
    background-color: #e67e00;
  }

  .btn-secondary {
    background-color: transparent;
    color: var(--color-text);
    border: 1px solid var(--color-border);
  }

  .btn-secondary:hover {
    background-color: var(--color-hover-bg);
  }
</style>

<script>
  const dialog = document.getElementById('contact-dialog') as HTMLDialogElement;
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const closeBtns = document.querySelectorAll('.close-dialog');

  // Open dialog when any link with class .open-contact-dialog is clicked
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (target.classList.contains('open-contact-dialog') || target.closest('.open-contact-dialog')) {
      e.preventDefault();
      dialog.showModal();
    }
  });

  // Close dialog logic
  closeBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      dialog.close();
    });
  });

  // Close when clicking outside the dialog (on the backdrop)
  dialog.addEventListener('click', (e) => {
    if (e.target === dialog) {
      dialog.close();
    }
  });

  // Handle form submit by constructing a mailto link
  form.addEventListener('submit', (e) => {
    e.preventDefault();
    const formData = new FormData(form);
    const motivo = formData.get('motivo');
    const modelo = formData.get('modelo');
    const descripcion = formData.get('descripcion');

    const subject = encodeURIComponent(`Consulta Zorzal RF: ${motivo} - ${modelo}`);
    const body = encodeURIComponent(
      `Motivo de Consulta: ${motivo}\n` +
      `Modelo/Proyecto: ${modelo}\n\n` +
      `Descripción:\n${descripcion}`
    );

    window.location.href = `mailto:hola@zorzalrf.com?subject=${subject}&body=${body}`;
    dialog.close();
    form.reset();
  });
</script>
