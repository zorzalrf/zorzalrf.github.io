---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactDialog from '../components/ContactDialog.astro';
import SEO from '../components/SEO.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Zorzal RF - Soluciones Técnicas y Tutoriales de Radiofrecuencia" } = Astro.props;
const gaId = 'G-RFXJ47L4P6';
---

<!doctype html>
<html lang="es-AR">
  <head>
    <meta charset="UTF-8" />
    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        return 'light';
      })();
      if (theme === 'dark') {
        document.documentElement.classList.add('theme-dark');
      } else {
        document.documentElement.classList.remove('theme-dark');
      }
    </script>
    <!-- Google tag (gtag.js) -->
    {gaId && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
        <script is:inline define:vars={{ gaId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());

          gtag('config', gaId);
        </script>
      </>
    )}
    <SEO title={title} description={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <meta name="generator" content={Astro.generator} />
    <!-- KaTeX CSS for rendering math formulas -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css" crossorigin="anonymous">
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <ContactDialog />
  </body>
</html>

<style>
  html, body {
    height: 100%;
    display: flex;
    flex-direction: column;
  }
  body {
    min-height: 100vh;
  }
  main {
    flex: 1;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
    box-sizing: border-box;
  }
</style>
