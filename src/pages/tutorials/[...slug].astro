---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  // If the collection doesn't exist yet, return an empty array
  // This prevents build errors when there are no markdown files
  try {
    const tutorialEntries = await getCollection('tutorials');
    return tutorialEntries.map(entry => ({
      params: { slug: entry.slug }, props: { entry },
    }));
  } catch (e) {
    return [];
  }
}

const { entry } = Astro.props;
if (!entry) {
    return Astro.redirect('/404');
}
const { Content } = await entry.render();
---

<Layout title={entry.data.title} description={entry.data.description}>
  <article class="tutorial-content">
    <header>
      <h1>{entry.data.title}</h1>
      <p class="description">{entry.data.description}</p>
      <div class="meta">
        <span>Publicado el {new Date(entry.data.publishDate).toLocaleDateString('es-AR')}</span>
        <span>Por {entry.data.author}</span>
      </div>
    </header>
    
    <div class="prose">
      <Content />
    </div>
  </article>
</Layout>

<style>
  .tutorial-content {
    max-width: 800px;
    margin: 0 auto;
  }
  
  header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }
  
  h1 {
    font-size: 2.5rem;
    color: var(--color-orange);
    margin-bottom: 0.5rem;
  }
  
  .description {
    font-size: 1.25rem;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }
  
  .meta {
    display: flex;
    gap: 2rem;
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }
  
  /* Styling for the markdown content */
  .prose {
    line-height: 1.8;
    font-size: 1.1rem;
    color: var(--color-text);
  }
  
  .prose :global(h2) {
    color: var(--color-heading);
    font-size: 1.75rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }
  
  .prose :global(h3) {
    color: var(--color-heading);
    font-size: 1.4rem;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  
  .prose :global(a) {
    color: var(--color-orange);
  }
  
  .prose :global(code) {
    background: var(--color-code-bg);
    padding: 0.2em 0.4em;
    border-radius: 3px;
    font-family: monospace;
    font-size: 0.9em;
  }
  
  .prose :global(pre) {
    background: var(--color-code-bg);
    padding: 1.5rem;
    border-radius: 8px;
    overflow-x: auto;
    border: 1px solid var(--color-border);
  }
  
  .prose :global(pre code) {
    background: none;
    padding: 0;
  }
</style>
