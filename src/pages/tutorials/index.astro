---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// This will fetch from src/content/tutorials
// If no tutorials exist, it returns an empty array
const tutorials = await getCollection('tutorials').catch(() => []);
---

<Layout title="Tutoriales">
  <div class="tutorials-header">
    <h1>Tutoriales Técnicos</h1>
    <p>Aprendé sobre SDR, ADS-B e ingeniería de RF con nuestros expertos.</p>
  </div>

  <div class="search-container">
    <input type="search" id="tutorial-search" placeholder="Buscar tutoriales por título, descripción o etiqueta..." />
  </div>

  {tutorials.length === 0 ? (
    <div class="empty-state">
      <p>Todavía no hay tutoriales disponibles. Por favor, agregá archivos markdown a <code>src/content/tutorials/</code>.</p>
    </div>
  ) : (
    <ul class="tutorial-list">
      {tutorials.map((tutorial) => (
        <li class="tutorial-item" data-search={`${tutorial.data.title} ${tutorial.data.description} ${tutorial.data.tags?.join(' ') || ''}`.toLowerCase()}>
          <a href={import.meta.env.BASE_URL + 'tutorials/' + tutorial.slug + '/'} class="tutorial-card">
            <h2>{tutorial.data.title}</h2>
            <p>{tutorial.data.description}</p>
            <div class="meta">
              <span class="author">Por {tutorial.data.author}</span>
              <span class="date">{new Date(tutorial.data.publishDate).toLocaleDateString('es-AR')}</span>
            </div>
          </a>
        </li>
      ))}
    </ul>
  )}
</Layout>

<style>
  .tutorials-header {
    margin-bottom: 3rem;
  }
  
  .tutorials-header h1 {
    font-size: 2.5rem;
    color: var(--color-orange);
  }
  
  .empty-state {
    background: var(--color-card-bg);
    padding: 2rem;
    border-radius: 8px;
    text-align: center;
    border: 1px dashed var(--color-border);
  }

  .search-container {
    margin-bottom: 2rem;
  }
  
  #tutorial-search {
    width: 100%;
    padding: 1rem 1.5rem;
    font-size: 1.1rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background-color: var(--color-card-bg);
    color: var(--color-text);
    transition: all 0.2s ease-in-out;
  }
  
  #tutorial-search:focus {
    outline: none;
    border-color: var(--color-orange);
    box-shadow: 0 4px 12px rgba(255, 140, 0, 0.15);
    transform: translateY(-2px);
  }
  
  .tutorial-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  
  .tutorial-card {
    display: block;
    background: var(--color-card-bg);
    border: 1px solid var(--color-border);
    padding: 1.5rem;
    border-radius: 8px;
    text-decoration: none;
    transition: transform 0.2s, border-color 0.2s;
  }
  
  .tutorial-card:hover {
    transform: translateX(4px);
    border-color: var(--color-orange);
  }
  
  .tutorial-card h2 {
    color: var(--color-heading);
    margin: 0 0 0.5rem 0;
    font-size: 1.5rem;
  }
  
  .tutorial-card p {
    color: var(--color-text-muted);
    margin: 0 0 1.5rem 0;
  }
  
  .meta {
    display: flex;
    justify-content: space-between;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    border-top: 1px solid var(--color-border);
    padding-top: 1rem;
  }
</style>

<script>
  const searchInput = document.getElementById('tutorial-search') as HTMLInputElement;
  const tutorialItems = document.querySelectorAll('.tutorial-item');

  searchInput?.addEventListener('input', (e) => {
    const query = (e.target as HTMLInputElement).value.toLowerCase();

    tutorialItems.forEach((item) => {
      const searchData = item.getAttribute('data-search') || '';
      if (searchData.includes(query)) {
        (item as HTMLElement).style.display = 'block';
      } else {
        (item as HTMLElement).style.display = 'none';
      }
    });
  });
</script>
