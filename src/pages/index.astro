---
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
---

<Layout title="Inicio">
  <section class="hero">
    <h1>Componentes y Soluciones para Recepción de Alta Performance</h1>
    <p>Nos especializamos en Radio Definida por Software (SDR), rastreo ADS-B y sistemas de RF especializados.</p>
    <div class="cta-group">
      <a href={import.meta.env.BASE_URL + 'catalog/'} class="button primary">Ver Catálogo</a>
      <!--<a href={import.meta.env.BASE_URL + 'tutorials/'} class="button secondary">Leer Tutoriales</a>-->
    </div>
  </section>

  <section class="featured">
    <h2>Equipos Destacados</h2>
    <div class="product-grid">
      <ProductCard 
        title="RTL-SDR Blog Multipurpose Dipole Antenna Kit"
        category="Entrega Inmediata" 
        specs={["Base dipolo versátil con cable RG174 de 60 cm", "Incluye 4 antenas telescópicas intercambiables", "Cable de extensión RG174 de 3 metros", "Soportes incluidos: trípode flexible y ventosa", "Diseño adaptable para uso temporal en exteriores"]} 
    idealUse="Kit completo para iniciarse en radioescucha."
        type= {["Antena"]}
    />
    <ProductCard
        title="RTL-SDR Blog V3 R860 (USB-C)"
        type= {["SDR"]}
        specs={[
      "Versión actualizada con conector USB-C hembra",
      "Tuner R860 (R820T2) con TCXO de 1 PPM",
      "Carcasa de aluminio con disipación pasiva",
      "Protección ESD mejorada contra sobretensiones",
      "Muestreo directo integrado para bandas HF"
    ]}
    idealUse="Receptor SDR optimizado para dispositivos modernos.",
    category="Entrega Inmediata"
    />
    </div>
  </section>
</Layout>

<style>
  .hero {
    text-align: center;
    padding: 4rem 0;
    margin-bottom: 3rem;
  }
  
  .hero h1 {
    font-size: 3rem;
    color: var(--color-orange);
    margin-bottom: 1rem;
  }
  
  .hero p {
    font-size: 1.25rem;
    color: var(--color-text-muted);
    max-width: 800px;
    margin: 0 auto 2rem;
  }
  
  .cta-group {
    display: flex;
    justify-content: center;
    gap: 1rem;
  }
  
  .button {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    border-radius: 4px;
    font-weight: bold;
    text-decoration: none;
    transition: all 0.2s;
  }
  
  .button.primary {
    background-color: var(--color-orange);
    color: var(--color-dark-gray);
  }
  
  .button.primary:hover {
    background-color: #e67e00;
  }
  
  .button.secondary {
    background-color: transparent;
    color: var(--color-orange);
    border: 2px solid var(--color-orange);
  }
  
  .button.secondary:hover {
    background-color: rgba(255, 140, 0, 0.1);
  }
  
  .featured h2 {
    font-size: 2rem;
    margin-bottom: 2rem;
    border-bottom: 2px solid var(--color-border);
    padding-bottom: 0.5rem;
  }
  
  .product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2rem;
  }
</style>
