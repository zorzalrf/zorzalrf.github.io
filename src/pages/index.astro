---
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
---

<Layout title="Inicio" description="Especialistas en Radio Definida por Software (SDR) y sistemas de RF. Hardware testeado, antenas y kits completos para recepción de alta performance.">
  <section class="hero">
    <h1>Componentes y Soluciones para Recepción de Alta Performance</h1>
    <p>Nos especializamos en Radio Definida por Software (SDR) y sistemas de RF especializados.</p>
    <p class="authority-text">Hardware original, seleccionado y testeado.</p>
    <div class="cta-group">
      <a href={import.meta.env.BASE_URL + 'catalogo/'} class="button primary">Ver Catálogo</a>
    <a href={import.meta.env.BASE_URL + 'recursos/'} class="button secondary">Ir al Centro de Recursos</a>
    </div>
  </section>

  <section class="featured">
    <h2>Equipos Destacados</h2>
    <div class="product-grid">
      <ProductCard 
        title="Kit RTL-SDR Blog V3 + Antena Dipolo - SDR Completo"
        category="Entrega Inmediata" 
        specs={["Tuner R860 (R820T2) con oscilador TCXO de 1 PPM", "Compatible con SDRSharp, GQRX y HDSDR", "Circuito Bias-Tee conmutable vía software", "Protección ESD adicional y bajo nivel de ruido", "Incluye base dipolo, cables y soportes"]} 
        idealUse="Kit completo para iniciarse en radioescucha."
        type={["SDR", "Antenas"]}
        isHero={true}
        badge="RECOMENDADO PARA PRINCIPIANTES"
      />
      <ProductCard
        title="Kit ADS-B 1090 MHz Profesional: Antena + Filtro + Cable"
        category="Entrega Inmediata"
        type={["Antenas", "Filtros", "Accesorios"]}
        specs={[
          "Antena exterior 5.5 dBi con conector tipo N",
          "Filtro SAW pasabanda 1090 MHz",
          "Cable coaxial KMR-240 de bajas pérdidas",
          "Pigtails y adaptadores incluidos",
          "Mejora el alcance de tu receptor en hasta un 300%"
        ]}
        idealUse="Kit integral para montar tu propio radar de aviones."
      />
      <ProductCard
        title="Receptor RTL-SDR Blog V3 - HF/VHF/UHF TCXO 1PPM"
        type={["SDR"]}
        specs={[
          "Tuner R860 (R820T2) con oscilador TCXO de 1 PPM",
          "Compatible con SDRSharp, GQRX y HDSDR",
          "Muestreo directo integrado para recepción HF básica",
          "Carcasa metálica blindada para reducción de ruido",
          "Circuito Bias-Tee interno para alimentación de accesorios"
        ]}
        idealUse="Receptor SDR versátil de excelente valor."
        category="Entrega Inmediata"
      />
    </div>
  </section>
</Layout>

<style>
  .hero {
    text-align: center;
    padding: 4rem 0;
    margin-bottom: 3rem;
  }
  
  .hero h1 {
    font-size: 3rem;
    color: var(--color-orange);
    margin-bottom: 1rem;
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: normal;
  }
  
  .hero p {
    font-size: 1.25rem;
    color: var(--color-text-muted);
    max-width: 800px;
    margin: 0 auto 1.5rem;
  }

  .authority-text {
    font-size: 1rem;
    color: var(--color-text);
    font-weight: 500;
    margin-bottom: 2rem;
  }
  
  .cta-group {
    display: flex;
    justify-content: center;
    gap: 1rem;
  }
  
  .button {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    border-radius: 4px;
    font-weight: bold;
    text-decoration: none;
    transition: all 0.2s;
  }
  
  .button.primary {
    background-color: var(--color-orange);
    color: var(--color-dark-gray);
  }
  
  .button.primary:hover {
    background-color: #e67e00;
  }
  
  .button.secondary {
    background-color: transparent;
    color: var(--color-orange);
    border: 2px solid var(--color-orange);
  }
  
  .button.secondary:hover {
    background-color: rgba(255, 140, 0, 0.1);
  }
  
  .featured h2 {
    font-size: 2rem;
    margin-bottom: 2rem;
    border-bottom: 2px solid var(--color-border);
    padding-bottom: 0.5rem;
  }
  
  .product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2rem;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 0.5rem 0 2rem;
      margin-bottom: 2rem;
    }
    .hero h1 {
      font-size: 2.25rem;
    }
    .hero p {
      font-size: 1.1rem;
    }
    .cta-group {
      flex-direction: column;
      gap: 1rem;
    }
  }
</style>
