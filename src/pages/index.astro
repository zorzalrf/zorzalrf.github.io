---
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
---

<Layout title="Inicio">
  <section class="hero">
    <h1>Componentes y Soluciones para Recepción de Alta Performance</h1>
    <p>Nos especializamos en Radio Definida por Software (SDR) y sistemas de RF especializados.</p>
    <p class="authority-text">Hardware original, seleccionado y testeado.</p>
    <div class="cta-group">
      <a href={import.meta.env.BASE_URL + 'catalog/'} class="button primary">Ver Catálogo</a>
    <a href={import.meta.env.BASE_URL + 'resources/'} class="button secondary">Ir al Centro de Recursos</a>
    </div>
  </section>

  <section class="featured">
    <h2>Equipos Destacados</h2>
    <div class="product-grid">
      <ProductCard 
        title="Kit RTL-SDR Blog V3 + Antena Dipolo - SDR Completo"
        category="Entrega Inmediata" 
        specs={["Tuner R860 (R820T2) con oscilador TCXO de 1 PPM", "Compatible con SDRSharp, GQRX y HDSDR", "Circuito Bias-Tee conmutable vía software", "Protección ESD adicional y bajo nivel de ruido", "Incluye base dipolo, cables y soportes"]} 
        idealUse="Kit completo para iniciarse en radioescucha."
        type={["SDR", "Antena"]}
        isHero={true}
        badge="RECOMENDADO PARA PRINCIPIANTES"
      />
      <ProductCard
        title="Estación ADS-B: Receptor V3 + Antena + Filtro"
        category="Entrega Inmediata"
        type={["SDR", "Antena", "Filtros"]}
        specs={[
          "Receptor RTL-SDR Blog V3 (Carcasa de aluminio)",
          "Antena exterior 5.5 dBi 1090 MHz con conector N",
          "Filtro SAW 1090 MHz para rechazo de interferencias",
          "Cableado KMR de bajas pérdidas y adaptadores",
          "Kit completo llave en mano para montar un radar local"
        ]}
        idealUse="Kit integral para montar tu propio radar de aviones."
      />
      <ProductCard
        title="Airspy HF+ Discovery - Receptor SDR de alta performance"
        category="Entrega 30 días"
        type={["SDR"]}
        specs={[
          "Rango de frecuencia optimizado para bandas HF y VHF",
          "Arquitectura Zero-IF con filtros de seguimiento de alta selectividad",
          "Rango dinámico de clase mundial en entornos HF",
          "ADC de alto rendimiento para una mínima distorsión de señal",
          "Interfaz USB para procesamiento digital de señal"
        ]}
        idealUse="Monitoreo avanzado de alta precisión en HF."
      />
    </div>
  </section>
</Layout>

<style>
  .hero {
    text-align: center;
    padding: 4rem 0;
    margin-bottom: 3rem;
  }
  
  .hero h1 {
    font-size: 3rem;
    color: var(--color-orange);
    margin-bottom: 1rem;
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: normal;
  }
  
  .hero p {
    font-size: 1.25rem;
    color: var(--color-text-muted);
    max-width: 800px;
    margin: 0 auto 1.5rem;
  }

  .authority-text {
    font-size: 1rem;
    color: var(--color-text);
    font-weight: 500;
    margin-bottom: 2rem;
  }
  
  .cta-group {
    display: flex;
    justify-content: center;
    gap: 1rem;
  }
  
  .button {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    border-radius: 4px;
    font-weight: bold;
    text-decoration: none;
    transition: all 0.2s;
  }
  
  .button.primary {
    background-color: var(--color-orange);
    color: var(--color-dark-gray);
  }
  
  .button.primary:hover {
    background-color: #e67e00;
  }
  
  .button.secondary {
    background-color: transparent;
    color: var(--color-orange);
    border: 2px solid var(--color-orange);
  }
  
  .button.secondary:hover {
    background-color: rgba(255, 140, 0, 0.1);
  }
  
  .featured h2 {
    font-size: 2rem;
    margin-bottom: 2rem;
    border-bottom: 2px solid var(--color-border);
    padding-bottom: 0.5rem;
  }
  
  .product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2rem;
  }
</style>
