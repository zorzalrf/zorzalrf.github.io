---
import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
// In a real app, you would use getCollection('catalog')
// We are hardcoding some for demo purposes as requested by the structure
import { catalogItems } from '../../data/catalog';

const heroItems = catalogItems.filter(item => item.isHero && item.category !== 'Sin Stock');
const outOfStockItems = catalogItems.filter(item => item.category === 'Sin Stock');
const otherItems = catalogItems.filter(item => !item.isHero && item.category !== 'Sin Stock').sort(() => Math.random() - 0.5);

const sortedItems = [...heroItems, ...otherItems, ...outOfStockItems];
---

<Layout title="Catálogo">
  <div class="catalog-header">
    <h1>Catálogo de Productos</h1>
    <p>Explorá nuestra selección de equipos y componentes de RF especializados.</p>
  </div>

  <div class="filters">
    <span class="filter-label">Filtrar por Entrega:</span>
    <button class="filter-btn filter-delivery-btn active" data-delivery="all">Todos</button>
    <button class="filter-btn filter-delivery-btn" data-delivery="Entrega Inmediata" style="border-color: #4ade80;">Inmediata</button>
    <button class="filter-btn filter-delivery-btn" data-delivery="Entrega 30 días" style="border-color: #facc15;">30 Días</button>
    <button class="filter-btn filter-delivery-btn" data-delivery="Entrega 45 días" style="border-color: #f87171;">45 Días</button>
  </div>

  <div class="filters">
    <span class="filter-label">Filtrar por Tipo:</span>
    <button class="filter-btn filter-type-btn active" data-type="all">Todos</button>
    <button class="filter-btn filter-type-btn" data-type="SDR" style="border-color: #60a5fa;">SDR</button>
    <button class="filter-btn filter-type-btn" data-type="Antena" style="border-color: #a78bfa;">Antena</button>
    <button class="filter-btn filter-type-btn" data-type="Accesorios" style="border-color: #f472b6;">Accesorios</button>
    <button class="filter-btn filter-type-btn" data-type="Filtros" style="border-color: #38bdf8;">Filtros</button>
  </div>

  <div class="product-grid">
    {sortedItems.map(item => (
      <ProductCard 
        title={item.title} 
        category={item.category} 
        type={item.type}
        specs={item.specs} 
        idealUse={item.idealUse}
        isHero={item.isHero}
        badge={item.badge}
      />
    ))}
  </div>
</Layout>

<style>
  .catalog-header {
    margin-bottom: 2rem;
  }
  
  .catalog-header h1 {
    font-size: 2.5rem;
    color: var(--color-orange);
  }
  
  .filters {
    display: flex;
    gap: 1rem;
    margin-bottom: 2rem;
    align-items: center;
    flex-wrap: wrap;
  }
  
  .filter-label {
    font-weight: bold;
    color: var(--color-text-muted);
  }
  
  .filter-btn {
    background: transparent;
    color: var(--color-text);
    border: 1px solid var(--color-border);
    padding: 0.4rem 1rem;
    border-radius: 4px;
    cursor: pointer;
    transition: all 0.2s;
  }
  
  .filter-btn:hover, .filter-btn.active {
    background: var(--color-hover-bg);
  }
  
  .product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2rem;
  }
</style>

<script>
  const deliveryButtons = document.querySelectorAll('.filter-delivery-btn');
  const typeButtons = document.querySelectorAll('.filter-type-btn');
  const cards = document.querySelectorAll('.product-card');

  let currentDelivery = 'all';
  let currentType = 'all';

  // Read URL parameters for automatic filtering
  const urlParams = new URLSearchParams(window.location.search);
  const typeParam = urlParams.get('type');

  if (typeParam) {
    currentType = typeParam;
    currentDelivery = 'all'; // Show all delivery options when coming from a specific category link

    // Update UI active classes for types
    typeButtons.forEach(btn => {
      if (btn.getAttribute('data-type') === currentType) {
        btn.classList.add('active');
      } else {
        btn.classList.remove('active');
      }
    });

    // Update UI active classes for delivery
    deliveryButtons.forEach(btn => {
      if (btn.getAttribute('data-delivery') === currentDelivery) {
        btn.classList.add('active');
      } else {
        btn.classList.remove('active');
      }
    });
  }

  function updateGrid() {
    cards.forEach(card => {
      const matchDelivery = currentDelivery === 'all' || card.getAttribute('data-category') === currentDelivery;
      const matchType = currentType === 'all' || (card.getAttribute('data-type') || '').split(',').includes(currentType);
      
      if (matchDelivery && matchType) {
        (card as HTMLElement).style.display = 'flex';
      } else {
        (card as HTMLElement).style.display = 'none';
      }
    });
  }

  // Initial call to set correct visibility based on default filters
  updateGrid();

  deliveryButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      deliveryButtons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      currentDelivery = btn.getAttribute('data-delivery') || 'all';
      updateGrid();
    });
  });

  typeButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      typeButtons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      currentType = btn.getAttribute('data-type') || 'all';
      updateGrid();
    });
  });
</script>
