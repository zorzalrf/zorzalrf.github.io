---
import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
// In a real app, you would use getCollection('catalogo')
// We are hardcoding some for demo purposes as requested by the structure
import { catalogoItems } from '../../data/catalogo';

export function getStaticPaths() {
  return [
    { params: { path: undefined } },
    { params: { path: 'sdr' } },
    { params: { path: 'antenas' } },
    { params: { path: 'accesorios' } },
    { params: { path: 'filtros' } },
  ];
}

const heroItems = catalogoItems.filter(item => item.isHero && item.category !== 'Sin Stock');
const outOfStockItems = catalogoItems.filter(item => item.category === 'Sin Stock');
const otherItems = catalogoItems.filter(item => !item.isHero && item.category !== 'Sin Stock').sort(() => Math.random() - 0.5);

const sortedItems = [...heroItems, ...otherItems, ...outOfStockItems];
---

<Layout title="Catálogo" description="Explorá nuestro catálogo de equipos y componentes de RF. Encontrá receptores SDR, antenas, filtros y accesorios para tu estación de radio.">
  <div class="catalogo-header">
    <h1>Catálogo de Productos</h1>
    <p>Explorá nuestra selección de equipos y componentes de RF especializados.</p>
  </div>


  <div class="filters">
    <span class="filter-label">Filtrar por Tipo:</span>
    <button class="filter-btn filter-type-btn active" data-type="all">Todos</button>
    <button class="filter-btn filter-type-btn" data-type="SDR" style="border-color: #60a5fa;">SDR</button>
    <button class="filter-btn filter-type-btn" data-type="Antenas" style="border-color: #a78bfa;">Antenas</button>
    <button class="filter-btn filter-type-btn" data-type="Accesorios" style="border-color: #f472b6;">Accesorios</button>
    <button class="filter-btn filter-type-btn" data-type="Filtros" style="border-color: #38bdf8;">Filtros</button>
  </div>

  <div class="product-grid">
    {sortedItems.map(item => (
      <ProductCard 
        title={item.title} 
        category={item.category} 
        type={item.type}
        specs={item.specs} 
        idealUse={item.idealUse}
        isHero={item.isHero}
        badge={item.badge}
      />
    ))}
  </div>
</Layout>

<style>
  .catalogo-header {
    margin-bottom: 2rem;
  }
  
  .catalogo-header h1 {
    font-size: 2.5rem;
    color: var(--color-orange);
  }
  
  .filters {
    display: flex;
    gap: 1rem;
    margin-bottom: 2rem;
    align-items: center;
    flex-wrap: wrap;
  }
  
  .filter-label {
    font-weight: bold;
    color: var(--color-text-muted);
  }
  
  .filter-btn {
    background: transparent;
    color: var(--color-text);
    border: 1px solid var(--color-border);
    padding: 0.4rem 1rem;
    border-radius: 4px;
    cursor: pointer;
    transition: all 0.2s;
  }
  
  .filter-btn:hover, .filter-btn.active {
    background: var(--color-hover-bg);
  }
  
  .product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2rem;
  }
</style>

<script>

  const typeButtons = document.querySelectorAll('.filter-type-btn');
  const cards = document.querySelectorAll('.product-card');


  let currentType = 'all';

  // Read URL path for automatic filtering
  const pathParts = window.location.pathname.split('/').filter(Boolean);
  const catalogoIndex = pathParts.indexOf('catalogo');
  
  if (catalogoIndex !== -1 && pathParts.length > catalogoIndex + 1) {
    const typeFromPath = pathParts[catalogoIndex + 1].toLowerCase();
    const typeMap: Record<string, string> = {
      'sdr': 'SDR',
      'antenas': 'Antenas',
      'accesorios': 'Accesorios',
      'filtros': 'Filtros'
    };
    if (typeMap[typeFromPath]) {
      currentType = typeMap[typeFromPath];
    }
  }

  // Also support legacy URL parameters just in case
  const urlParams = new URLSearchParams(window.location.search);
  const typeParam = urlParams.get('type');
  if (typeParam) {
    currentType = typeParam;
  }

  if (currentType !== 'all') {
    // Update UI active classes for types
    typeButtons.forEach(btn => {
      if (btn.getAttribute('data-type') === currentType) {
        btn.classList.add('active');
      } else {
        btn.classList.remove('active');
      }
    });
  }

  function updateGrid() {
    cards.forEach(card => {
      const matchType = currentType === 'all' || (card.getAttribute('data-type') || '').split(',').includes(currentType);
      
      if (matchType) {
        (card as HTMLElement).style.display = 'flex';
      } else {
        (card as HTMLElement).style.display = 'none';
      }
    });
  }

  // Initial call to set correct visibility based on default filters
  updateGrid();


  typeButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      typeButtons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      currentType = btn.getAttribute('data-type') || 'all';
      updateGrid();
      
      // Update URL without reloading
      const urlType = currentType.toLowerCase();
      const basePathMatch = window.location.pathname.match(/^(.*\/catalogo)/);
      const basePath = basePathMatch ? basePathMatch[1] : '/catalogo';
      const newUrl = currentType === 'all' 
        ? `${basePath}/`
        : `${basePath}/${urlType}`;
      window.history.pushState({}, '', newUrl);
    });
  });
</script>
