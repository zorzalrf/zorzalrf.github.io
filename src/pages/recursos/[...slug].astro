---
import { getCollection } from 'astro:content';
import DocsLayout from '../../layouts/DocsLayout.astro';

export async function getStaticPaths() {
  try {
    const tutorialEntries = await getCollection('recursos');
    return tutorialEntries.map(entry => ({
      params: { slug: entry.slug }, props: { entry },
    }));
  } catch (e) {
    return [];
  }
}

const { entry } = Astro.props;
if (!entry) {
    return Astro.redirect('/404');
}
const { Content } = await entry.render();

const getDifficultyClass = (diff: string) => {
  if (diff === 'Principiante') return 'diff-principiante';
  if (diff === 'Intermedio') return 'diff-intermedio';
  if (diff === 'Avanzado') return 'diff-avanzado';
  if (diff === 'Experto') return 'diff-experto';
  return 'diff-default';
};

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": entry.data.title,
  "description": entry.data.description,
  "author": {
    "@type": "Person",
    "name": entry.data.author || "Zorzal RF"
  },
  "datePublished": new Date(entry.data.publishDate).toISOString(),
  "url": Astro.url.href
};
---

<DocsLayout title={entry.data.title} description={entry.data.description} type="article">
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <article class="tutorial-content">
    <header>
      <div class="tags-row">
        <span class={`difficulty-badge ${getDifficultyClass(entry.data.difficulty)}`}>
          {entry.data.difficulty}
        </span>
        <span class="reading-time">⏱️ {entry.data.readingTime} min</span>
        <span class="category-tag">{entry.data.category}</span>
      </div>
      <h1>{entry.data.title}</h1>
      <p class="description">{entry.data.description}</p>
      <div class="meta">
        <span>Ultima actualización: {new Date(entry.data.publishDate).toLocaleDateString('es-AR')}</span>
        <span>Por {entry.data.author}</span>
      </div>
    </header>
    
    <div class="prose">
      <Content />
    </div>
  </article>
</DocsLayout>

<style>
  .tutorial-content {
    max-width: 800px;
    margin: 0 auto;
  }
  
  header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }
  
  h1 {
    font-size: 2.5rem;
    color: var(--color-orange);
    margin-bottom: 0.5rem;
  }
  
  .tags-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
    font-weight: 600;
  }

  .difficulty-badge {
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-size: 0.8rem;
    font-weight: bold;
    border: 1px solid transparent;
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
  }

  .diff-principiante {
    background-color: rgba(74, 222, 128, 0.15);
    color: #166534;
    border-color: rgba(74, 222, 128, 0.4);
  }
  .diff-intermedio {
    background-color: rgba(250, 204, 21, 0.15);
    color: #854d0e;
    border-color: rgba(250, 204, 21, 0.4);
  }
  .diff-avanzado {
    background-color: rgba(249, 115, 22, 0.15);
    color: #9a3412;
    border-color: rgba(249, 115, 22, 0.4);
  }
  .diff-experto {
    background-color: rgba(239, 68, 68, 0.15);
    color: #991b1b;
    border-color: rgba(239, 68, 68, 0.4);
  }
  .diff-default {
    background-color: rgba(156, 163, 175, 0.15);
    color: #374151;
    border-color: rgba(156, 163, 175, 0.4);
  }

  :global(.theme-dark) .diff-principiante {
    background-color: rgba(74, 222, 128, 0.1);
    color: #4ade80;
    border-color: rgba(74, 222, 128, 0.3);
  }
  :global(.theme-dark) .diff-intermedio {
    background-color: rgba(250, 204, 21, 0.1);
    color: #facc15;
    border-color: rgba(250, 204, 21, 0.3);
  }
  :global(.theme-dark) .diff-avanzado {
    background-color: rgba(249, 115, 22, 0.1);
    color: #f97316;
    border-color: rgba(249, 115, 22, 0.3);
  }
  :global(.theme-dark) .diff-experto {
    background-color: rgba(239, 68, 68, 0.1);
    color: #ef4444;
    border-color: rgba(239, 68, 68, 0.3);
  }
  :global(.theme-dark) .diff-default {
    background-color: rgba(156, 163, 175, 0.1);
    color: #9ca3af;
    border-color: rgba(156, 163, 175, 0.3);
  }

  .reading-time {
    color: var(--color-text-muted);
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
  }

  .category-tag {
    background-color: var(--color-border);
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
    color: var(--color-text);
    font-size: 0.8rem;
    font-weight: bold;
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
  }

  .description {
    font-size: 1.25rem;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }
  
  .meta {
    display: flex;
    gap: 2rem;
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }
  
  /* Styling for the markdown content */
  .prose {
    line-height: 1.8;
    font-size: 1.1rem;
    color: var(--color-text);
  }
  
  .prose :global(h2) {
    color: var(--color-heading);
    font-size: 1.75rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }
  
  .prose :global(h3) {
    color: var(--color-heading);
    font-size: 1.4rem;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  
  .prose :global(a) {
    color: var(--color-orange);
  }
  
  .prose :global(code) {
    background: var(--color-code-bg);
    padding: 0.2em 0.4em;
    border-radius: 3px;
    font-family: monospace;
    font-size: 0.9em;
    overflow-wrap: break-word;
    word-break: break-word;
  }
  
  .prose :global(pre) {
    background: var(--color-code-bg);
    padding: 1.5rem;
    border-radius: 8px;
    overflow-x: auto;
    border: 1px solid var(--color-border);
  }
  
  .prose :global(pre code) {
    background: none;
    padding: 0;
  }
  
  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 2rem 0;
    font-size: 0.95rem;
    background: var(--color-card-bg);
    border-radius: 8px;
    display: block;
    overflow-x: auto;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
  }

  .prose :global(th) {
    background-color: rgba(255, 140, 0, 0.1);
    color: var(--color-heading);
    font-weight: 700;
    text-align: left;
    padding: 1rem;
    border-bottom: 2px solid var(--color-orange);
  }

  .prose :global(td) {
    padding: 1rem;
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text);
    vertical-align: top;
  }

  .prose :global(tr:last-child td) {
    border-bottom: none;
  }

  .prose :global(tr:hover td) {
    background-color: var(--color-code-bg);
  }

  .prose :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    display: block;
    margin: 2rem auto;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
  }

  .prose :global(.attribution) {
    background: linear-gradient(to right, rgba(255, 140, 0, 0.08), transparent);
    border-left: 4px solid var(--color-orange);
    padding: 1.25rem 1.5rem;
    margin: 1.5rem 0 2.5rem 0;
    border-radius: 0 8px 8px 0;
    display: flex;
    gap: 1rem;
    align-items: center;
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }
  
  .prose :global(.attribution svg) {
    flex-shrink: 0;
    color: var(--color-orange);
  }

  .prose :global(.attribution p) {
    margin: 0;
    line-height: 1.6;
  }

  .prose :global(.attribution strong) {
    color: var(--color-heading);
  }
</style>
